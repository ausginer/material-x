{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext", "dom", "dom.iterable", "dom.asynciterable"],
    "types": [
      "vitest/importMeta",
      "vite/client",
      "vitest/globals",
      "@testing-library/jest-dom"
    ],
    "skipLibCheck": true,
    "useDefineForClassFields": true,

    /* Bundler mode */
    "declaration": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "isolatedDeclarations": true,

    /* Linting */
    "allowArbitraryExtensions": true,
    "strict": true,
    "strictBindCallApply": true,
    "sourceMap": true,
    "inlineSources": true,
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": true,
    "noUncheckedIndexedAccess": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitOverride": true,
    "noImplicitAny": true,
    "useUnknownInCatchVariables": true,
    "paths": {
      "ydin/package.json": ["./packages/ydin/package.json"],
      "ydin/*.js": ["./packages/ydin/src/*.ts"],
      "ydin/controllers/*.js": ["./packages/ydin/src/controllers/*.ts"],
      "ydin/traits/*.js": ["./packages/ydin/src/traits/*.ts"],
      "ydin/utils/*.js": ["./packages/ydin/src/utils/*.ts"]
    }
  }
}
