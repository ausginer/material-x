{
  "$schema": "https://typedoc.org/schema.json",
  "name": "ydin",
  "tsconfig": "./tsconfig.json",
  "entryPoints": ["./docs/api.ts"],
  "entryPointStrategy": "resolve",
  "readme": "none",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "intentionallyNotExported": [
    "$checkable",
    "$ctx",
    "$disableable",
    "$valuable",
    "Branded",
    "ConstructorStatics",
    "FieldsFromConverters",
    "Host",
    "PropsFromTraitFields",
    "TraitListProps",
    "TraitListStaticProps",
    "TraitProps",
    "TraitStaticProps"
  ],
  "sort": ["source-order"]
}
