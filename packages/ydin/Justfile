set shell := ["bash", "-euo", "pipefail", "-c"]

[private]
_eslint := "eslint --flag unstable_native_nodejs_ts_config -c eslint.config.ts"

# List available recipes
default:
    @just --list

# Build ydin
build:
    tsdown --config tsdown.config.ts

# Delete build artefacts
clean-build:
    node ../../.scripts/package-files.ts clean --package .

# Build TypeDoc API into the cache (dev/watch use)
docs-api:
    typedoc --options typedoc.json --out ../../node_modules/.cache/docs/api/ydin

# Build TypeDoc API into the output directory
docs-api-build:
    typedoc --options typedoc.json --out ../../.docs/api/ydin

# Run tests
test *ARGS:
    vitest run -c vitest.config.ts {{ ARGS }}

# Type-check
typecheck:
    tsgo -p tsconfig.json --noEmit

# Format files (paths are relative to this package)
fmt *FILES:
    oxfmt {{ if FILES == "" { "." } else { FILES } }}

# Check formatting without writing
fmt-check *FILES:
    oxfmt --check {{ if FILES == "" { "." } else { FILES } }}

# Lint files
lint *FILES:
    oxlint {{ if FILES == "" { "." } else { FILES } }}
    {{ _eslint }} {{ if FILES == "" { "." } else { FILES } }}

# Lint and auto-fix files
lint-fix *FILES:
    oxlint --fix {{ if FILES == "" { "." } else { FILES } }}
    {{ _eslint }} --fix {{ if FILES == "" { "." } else { FILES } }}
