{
  "name": "@ausginer/material-x",
  "version": "0.1.0",
  "description": "Material Design 3 Expressive dependless implementation for web",
  "homepage": "https://github.com/ausginer/material-x#readme",
  "bugs": {
    "url": "https://github.com/ausginer/material-x/issues"
  },
  "license": "Apache-2.0",
  "author": "Vlad Rindevich <github.aqwb5@mail.ausginer.com> (https://github.com/Lodin)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ausginer/material-x.git"
  },
  "files": [
    "button",
    "button-group",
    "custom-elements.json",
    "fab",
    "icon",
    "react.d.ts",
    "text-field"
  ],
  "type": "module",
  "exports": {
    "./button/button.js": {
      "types": "./button/button.d.ts",
      "default": "./button/button.js"
    },
    "./button/icon-button.js": {
      "types": "./button/icon-button.d.ts",
      "default": "./button/icon-button.js"
    },
    "./button/link-button.js": {
      "types": "./button/link-button.d.ts",
      "default": "./button/link-button.js"
    },
    "./button/switch-button.js": {
      "types": "./button/switch-button.d.ts",
      "default": "./button/switch-button.js"
    },
    "./button/switch-icon-button.js": {
      "types": "./button/switch-icon-button.d.ts",
      "default": "./button/switch-icon-button.js"
    },
    "./button/split-button.js": {
      "types": "./button/split-button.d.ts",
      "default": "./button/split-button.js"
    },
    "./button-group/button-group.js": {
      "types": "./button-group/button-group.d.ts",
      "default": "./button-group/button-group.js"
    },
    "./button-group/connected-button-group.js": {
      "types": "./button-group/connected-button-group.d.ts",
      "default": "./button-group/connected-button-group.js"
    },
    "./fab/fab.js": {
      "types": "./fab/fab.d.ts",
      "default": "./fab/fab.js"
    },
    "./icon/icon.js": {
      "types": "./icon/icon.d.ts",
      "default": "./icon/icon.js"
    },
    "./text-field/multiline-text-field.js": {
      "types": "./text-field/multiline-text-field.d.ts",
      "default": "./text-field/multiline-text-field.js"
    },
    "./text-field/text-field.js": {
      "types": "./text-field/text-field.d.ts",
      "default": "./text-field/text-field.js"
    },
    "./react.js": {
      "types": "./react.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run build:prepare && tsdown --config tsdown.config.ts && custom-elements-manifest analyze --config cem.config.ts",
    "build:prepare": "node ../../.scripts/css/collect-props.ts",
    "build:lib": "tsdown --config tsdown.config.ts",
    "build:cem": "custom-elements-manifest analyze --config cem.config.ts",
    "clean:build": "node ../../.scripts/package-files.ts clean --package .",
    "build:props": "npm run build:prepare",
    "docs:themes": "node ../../.scripts/storybook-theme.ts",
    "docs:prepare": "concurrently --kill-others-on-fail npm:docs:themes npm:build:props npm:build:cem",
    "docs:dev": "npm run docs:prepare && node ../../.scripts/storybook.ts dev --config-dir ../../.storybook -h 127.0.0.1 -p 6006 --ci",
    "docs:build": "npm run docs:prepare && node ../../.scripts/storybook.ts build --config-dir ../../.storybook -o ../../.docs",
    "publint": "publint",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "lint": "oxlint --type-aware . && eslint --flag unstable_native_nodejs_ts_config -c ../../eslint.config.ts .",
    "test": "vitest run -c vitest.config.ts && vitest run -c vitest.browser.config.ts",
    "test:browser": "vitest run -c vitest.browser.config.ts"
  },
  "dependencies": {
    "type-fest": "5.5.0",
    "ydin": "0.1.0"
  },
  "engines": {
    "node": ">=24"
  },
  "customElements": "custom-elements.json"
}
