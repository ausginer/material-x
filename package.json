{
  "name": "@ausginer/material-x-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "debug": "just debug",
    "build": "nx run-many -t build --projects=ydin,material-x --skipNxCache",
    "clean:build": "nx run-many -t clean:build --projects=ydin,material-x --skipNxCache",
    "check": "concurrently npm:fmt:check npm:lint npm:typecheck",
    "test": "nx run-many -t test --projects=ydin,material-x --skipNxCache",
    "docs": "just docs-build",
    "docs:dev": "just docs-dev",
    "fmt": "nx run-many -t fmt --projects=ydin,material-x --skipNxCache",
    "fmt:check": "nx run-many -t fmt:check --projects=ydin,material-x --skipNxCache",
    "lint": "concurrently npm:lint:packages",
    "lint:packages": "nx run-many -t lint --projects=ydin,material-x --skipNxCache",
    "lint:fix": "nx run-many -t lint:fix --projects=ydin,material-x --skipNxCache",
    "oxlint:migrate": "just oxlint-migrate",
    "typecheck": "nx run-many -t typecheck --projects=ydin,material-x --skipNxCache"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.11.0",
    "@eslint/config-helpers": "0.6.0",
    "@jridgewell/gen-mapping": "0.3.13",
    "@mdx-js/react": "3.1.1",
    "@minify-html/node": "0.18.1",
    "@preact/signals-core": "1.14.3",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-links": "10.4.6",
    "@storybook/addon-themes": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260620.1",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "concurrently": "10.0.3",
    "eslint": "9.39.2",
    "eslint-config-vaadin": "1.0.0-beta.6",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-oxlint": "1.70.0",
    "just-camel-case": "6.2.0",
    "just-kebab-case": "4.2.0",
    "just-safe-get": "4.2.0",
    "just-safe-set": "4.2.1",
    "lightningcss": "1.32.0",
    "magic-string": "0.30.21",
    "nx": "23.0.0",
    "oxc-transform": "0.137.0",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "playwright": "1.61.0",
    "publint": "0.3.21",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rolldown": "1.0.3",
    "rollup": "4.62.2",
    "rust-just": "1.53.0",
    "sorcery": "1.0.0",
    "storybook": "10.4.6",
    "tsdown": "0.22.3",
    "tsgolint": "0.0.1",
    "type-fest": "5.7.0",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vite-plugin-inspect": "11.4.1",
    "vitest": "4.1.9"
  },
  "overrides": {
    "@mdx-js/react": "$@mdx-js/react",
    "eslint": "$eslint",
    "react": "$react",
    "rolldown": "$rolldown",
    "typescript": "$typescript",
    "vite": "$vite"
  },
  "engines": {
    "node": ">=24"
  },
  "allowScripts": {
    "nx@23.0.0": true,
    "rs-module-lexer@2.8.0": true,
    "unrs-resolver@1.11.1": true,
    "esbuild@0.28.1": true
  }
}
