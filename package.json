{
  "name": "@ausginer/material-x-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "nx run-many -t build --projects=ydin,material-x --skipNxCache",
    "clean:build": "nx run-many -t clean:build --projects=ydin,material-x --skipNxCache",
    "check": "concurrently npm:fmt:check npm:lint npm:typecheck",
    "test": "nx run-many -t test --projects=ydin,material-x --skipNxCache",
    "docs": "npm run build -w ydin && npm run docs:build -w @ausginer/material-x",
    "docs:dev": "npm run build -w ydin && npm run docs:dev -w @ausginer/material-x",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "nx run-many -t lint --projects=ydin,material-x --skipNxCache",
    "lint:fix": "oxlint --type-aware --fix && eslint --flag unstable_native_nodejs_ts_config -c eslint.config.ts --fix",
    "typecheck": "nx run-many -t typecheck --projects=ydin,material-x --skipNxCache"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.11.0",
    "@eslint/config-helpers": "0.5.3",
    "@jridgewell/gen-mapping": "0.3.13",
    "@mdx-js/react": "3.1.1",
    "@minify-html/node": "0.18.1",
    "@preact/signals-core": "1.14.0",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/addon-themes": "10.3.3",
    "@storybook/react-vite": "10.3.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260324.1",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser": "4.1.1",
    "@vitest/browser-playwright": "4.1.1",
    "@vitest/coverage-v8": "4.1.1",
    "@vitest/ui": "4.1.1",
    "concurrently": "9.2.1",
    "eslint": "9.39.2",
    "eslint-config-vaadin": "1.0.0-beta.5",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-oxlint": "1.57.0",
    "just-camel-case": "6.2.0",
    "just-kebab-case": "4.2.0",
    "just-safe-get": "4.2.0",
    "just-safe-set": "4.2.1",
    "lightningcss": "1.30.0",
    "magic-string": "0.30.21",
    "nx": "22.6.1",
    "oxc-transform": "0.121.0",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.17.3",
    "playwright": "1.58.2",
    "publint": "0.3.18",
    "puppeteer-core": "24.40.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rollup": "4.60.0",
    "sorcery": "1.0.0",
    "storybook": "10.3.3",
    "tsdown": "0.21.4",
    "tsgolint": "0.0.1",
    "type-fest": "5.5.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.57.2",
    "vite": "8.0.2",
    "vite-plugin-inspect": "11.3.3",
    "vitest": "4.1.1"
  },
  "overrides": {
    "@mdx-js/react": "$@mdx-js/react",
    "eslint": "$eslint",
    "react": "$react",
    "typescript": "$typescript",
    "vite": "$vite"
  },
  "engines": {
    "node": ">=24"
  }
}
