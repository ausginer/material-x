{
  "name": "@ausginer/material-x-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "debug": "just debug",
    "build": "nx run-many -t build --projects=ydin,material-x --skipNxCache",
    "clean:build": "nx run-many -t clean:build --projects=ydin,material-x --skipNxCache",
    "check": "concurrently npm:fmt:check npm:lint npm:typecheck",
    "test": "nx run-many -t test --projects=ydin,material-x --skipNxCache",
    "docs": "just docs-build",
    "docs:dev": "just docs-dev",
    "fmt": "nx run-many -t fmt --projects=ydin,material-x --skipNxCache",
    "fmt:check": "nx run-many -t fmt:check --projects=ydin,material-x --skipNxCache",
    "lint": "concurrently npm:lint:packages",
    "lint:packages": "nx run-many -t lint --projects=ydin,material-x --skipNxCache",
    "lint:fix": "nx run-many -t lint:fix --projects=ydin,material-x --skipNxCache",
    "oxlint:migrate": "just oxlint-migrate",
    "typecheck": "nx run-many -t typecheck --projects=ydin,material-x --skipNxCache"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.11.0",
    "@eslint/config-helpers": "0.5.5",
    "@jridgewell/gen-mapping": "0.3.13",
    "@mdx-js/react": "3.1.1",
    "@minify-html/node": "0.18.1",
    "@preact/signals-core": "1.14.1",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-links": "10.3.5",
    "@storybook/addon-themes": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260416.2",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "4.1.4",
    "concurrently": "9.2.1",
    "eslint": "9.39.2",
    "eslint-config-vaadin": "1.0.0-beta.5",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-oxlint": "1.60.0",
    "just-camel-case": "6.2.0",
    "just-kebab-case": "4.2.0",
    "just-safe-get": "4.2.0",
    "just-safe-set": "4.2.1",
    "lightningcss": "1.30.0",
    "magic-string": "0.30.21",
    "nx": "22.6.5",
    "oxc-transform": "0.126.0",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.1",
    "playwright": "1.59.1",
    "publint": "0.3.18",
    "puppeteer-core": "24.41.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rolldown": "1.0.0-rc.16",
    "rollup": "4.60.1",
    "rust-just": "1.49.0",
    "sorcery": "1.0.0",
    "storybook": "10.3.5",
    "tsdown": "0.21.9",
    "tsgolint": "0.0.1",
    "type-fest": "5.5.0",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.8",
    "vite-plugin-inspect": "11.3.3",
    "vitest": "4.1.4"
  },
  "overrides": {
    "@mdx-js/react": "$@mdx-js/react",
    "eslint": "$eslint",
    "react": "$react",
    "rolldown": "$rolldown",
    "typescript": "$typescript",
    "vite": "$vite"
  },
  "engines": {
    "node": ">=24"
  }
}
